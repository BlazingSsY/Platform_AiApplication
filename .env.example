# Copy this file to .env.docker before running docker compose.

# PostgreSQL container settings.
POSTGRES_DB=dlsc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Backend database settings. Containers should use the compose service name.
DLSC_DB_HOST=postgres:5432
DLSC_DB_NAME=dlsc
DLSC_DB_USERNAME=postgres
DLSC_DB_PASSWORD=change-me
DLSC_DB_POOL_MIN=1
DLSC_DB_POOL_MAX=5

# Redis settings.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
SSO_REDIS_HOST=redis
SSO_REDIS_PORT=6379
SSO_REDIS_PASSWORD=
SSO_REDIS_DATABASE=0

# MinIO settings.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SERVER=minio:9000
MINIO_BUCKET=circuit-review
MINIO_ACCOUNT=minioadmin
MINIO_SECURITY=minioadmin
STORAGE_MINIO_ENABLE=true
STORAGE_LOCAL_ENABLE=false
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_LOCAL_JOB_PATH=/app/uploads

# External review engines. Keep host:port only; application.yml prepends http://.
REVIEW_SERVICE_URL=host.docker.internal:38080
CODE_REVIEW_SERVICE_URL=host.docker.internal:38081
LOGIC_REVIEW_SERVICE_URL=host.docker.internal:38082

# Cross-service backend URLs.
USER_SERVICE_URL=portal-backend:8011
CIRCUIT_SERVICE_URL=circuit-review-backend:8012
SOURCE_CODE_SERVICE_URL=sourcecode-review-backend:8013
DEPLOYMENT_TYPE=1

# SSO settings.
SPRING_PROFILES_ACTIVE=dev
SSO_SERVER_PORT=9091
SSO_MANAGEMENT_URL=http://portal-backend:8011/portal/v1
SSO_TOKEN_SIGN_KEY=air_secretKey
SSO_NODE_NUMBER=10
SSO_ACCESS_TOKEN_LIVE_SECONDS=43200
SSO_REFRESH_TOKEN_LIVE_SECONDS=86400
SSO_TGC_LIVE_IN_SECONDS=86400

# JVM settings.
JAVA_OPTS=-Xms512m -Xmx1024m

# Host port for the unified gateway. 8080 is often occupied by other services.
GATEWAY_PORT=18080
